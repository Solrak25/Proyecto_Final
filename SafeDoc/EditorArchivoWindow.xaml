<Window x:Class="SafeDoc.EditorArchivoWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Bloc de Notas Seguro" Height="500" Width="700"
        WindowStartupLocation="CenterOwner"
        Background="#202020"
        Foreground="#FFFFFF">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock x:Name="txtTitulo" Text="Visualizando Archivo" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,15" Foreground="#FFFFFF"/>
        
        <Border Grid.Row="1" Background="#202020" BorderBrush="#333333" BorderThickness="1" CornerRadius="4">
            <TextBox x:Name="txtContenido" 
                     AcceptsReturn="True" 
                     TextWrapping="Wrap" 
                     VerticalScrollBarVisibility="Auto"
                     Background="Transparent" 
                     Foreground="#CCCCCC" 
                     BorderThickness="0"
                     Padding="15"
                     FontSize="15"
                     FontFamily="Consolas" />
        </Border>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Descartar" Click="BtnCancelar_Click" Width="100" Height="36" Margin="0,0,15,0"
                    Background="#2D2D2D" Foreground="#FFFFFF" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="Guardar" Click="BtnGuardar_Click" Width="120" Height="36" IsDefault="True"
                    Background="#005FB8" Foreground="#FFFFFF" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="4"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>
