<Window x:Class="SafeDoc.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Crear Elemento" Height="200" Width="350"
        WindowStartupLocation="CenterOwner"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent">
    
    <Border Background="#202020" BorderBrush="#2D2D2D" BorderThickness="1" CornerRadius="8" Padding="20">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="5" Opacity="0.5" Color="Black"/>
        </Border.Effect>
        <StackPanel VerticalAlignment="Center">
            <TextBlock x:Name="txtTitulo" Text="Introduce el nombre:" Foreground="#FFFFFF" FontSize="14" Margin="0,0,0,10" FontWeight="SemiBold"/>
            <Border Background="#2D2D2D" CornerRadius="4" BorderBrush="#333333" BorderThickness="1">
                <TextBox x:Name="txtEntrada" FontSize="16" Height="32" Padding="8,0"
                         Background="Transparent" Foreground="#FFFFFF" BorderThickness="0" VerticalContentAlignment="Center" CaretBrush="#FFFFFF"/>
            </Border>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Cancelar" Click="BtnCancelar_Click" Width="80" Height="32" Margin="0,0,10,0"
                        Background="#2D2D2D" Foreground="#FFFFFF" BorderThickness="0" Cursor="Hand">
                     <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button Content="Aceptar" Click="BtnAceptar_Click" Width="80" Height="32" IsDefault="True"
                        Background="#005FB8" Foreground="#FFFFFF" BorderThickness="0" Cursor="Hand">
                     <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="4"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
