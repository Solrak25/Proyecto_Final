<Window x:Class="SafeDoc.TransferenciaRedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:SafeDoc"
        Title="Sincronización P2P" Height="450" Width="500"
        WindowStartupLocation="CenterOwner" Background="#121212" Foreground="#EEEEEE"
        BorderBrush="#2D2D2D" BorderThickness="1" WindowStyle="None" AllowsTransparency="True" MouseDown="Window_MouseDown">
    
    <Window.Resources>
        <Style TargetType="TabItem">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="border" Background="Transparent" Padding="15,10" BorderBrush="Transparent" BorderThickness="0,0,0,2">
                            <ContentPresenter x:Name="contentPresenter" ContentSource="Header" Focusable="False" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="#60CDFF"/>
                                <Setter Property="TextElement.Foreground" Value="#60CDFF" TargetName="contentPresenter"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="False">
                                <Setter Property="TextElement.Foreground" Value="#888888" TargetName="contentPresenter"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1AFFFFFF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Button" x:Key="ModernButton">
            <Setter Property="Background" Value="#2D2D2D"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Opacity" Value="0.8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter Property="ScaleTransform.ScaleX" Value="0.98"/>
                                <Setter Property="ScaleTransform.ScaleY" Value="0.98"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border BorderBrush="#333333" BorderThickness="1" CornerRadius="12" Background="#121212">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Stretch">
                <TextBlock Text="📶" FontSize="24" VerticalAlignment="Center" Margin="0,0,10,0" Foreground="#60CDFF"/>
                <TextBlock Text="Sincronización P2P" FontSize="22" FontWeight="Bold" Foreground="#FFFFFF" VerticalAlignment="Center"/>
                <Button Content="✕" HorizontalAlignment="Right" Click="BtnCerrar_Click" Background="Transparent" Foreground="#666" FontSize="18" Padding="5" Cursor="Hand" Margin="140,0,0,0">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <TextBlock Text="{TemplateBinding Content}" Foreground="{TemplateBinding Foreground}"/>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </StackPanel>

            <TextBlock Grid.Row="1" Text="Transfiere carpetas directamente a otro dispositivo en tu red local." 
                       Foreground="#888888" Margin="0,5,0,20" TextWrapping="Wrap"/>

            <TabControl Grid.Row="2" Background="Transparent" BorderThickness="0">
                <!-- PANEL EMISOR -->
                <TabItem Header="MODO EMISOR">
                    <StackPanel Margin="0,20,0,0">
                        <Border Background="#1E1E1E" CornerRadius="8" Padding="15" BorderBrush="#2D2D2D" BorderThickness="1">
                            <StackPanel>
                                <TextBlock Text="TU CÓDIGO DE RED" Foreground="#60CDFF" FontSize="12" FontWeight="Bold" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock x:Name="txtCodigoGenerado" Text="SAFE-ABC123XYZ" FontSize="18" 
                                               FontFamily="Consolas" VerticalAlignment="Center" Foreground="#FFFFFF"/>
                                    <Button Grid.Column="1" Click="BtnCopiar_Click" ToolTip="Copiar código" 
                                            Background="#2D2D2D" Cursor="Hand" Width="36" Height="36">
                                        <TextBlock Text="📋" FontSize="16"/>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Estado: Esperando a iniciar..." Margin="0,20,0,5" Foreground="#AAAAAA" FontStyle="Italic"/>
                        <Button x:Name="btnIniciarServidor" Content="INICIAR SERVIDOR DE ENVÍO" Style="{StaticResource ModernButton}" 
                                Click="BtnIniciarServidor_Click" Height="45" Background="#264F78" Margin="0,10,0,0"/>
                    </StackPanel>
                </TabItem>

                <!-- PANEL RECEPTOR -->
                <TabItem Header="MODO RECEPTOR">
                    <StackPanel Margin="0,20,0,0">
                        <TextBlock Text="PEGA EL CÓDIGO DEL EMISOR" Foreground="#AAAAAA" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBox x:Name="txtCodigoInput" Height="50" Background="#1E1E1E" Foreground="#60CDFF" 
                                 BorderBrush="#2D2D2D" BorderThickness="1" FontSize="20" Padding="10" 
                                 VerticalContentAlignment="Center" FontFamily="Consolas">
                            <TextBox.Resources>
                                <Style TargetType="{x:Type Border}">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        
                        <Button x:Name="btnConectar" Content="CONECTAR Y DESCARGAR" Style="{StaticResource ModernButton}" 
                                Click="BtnConectar_Click" Height="45" Margin="0,20,0,0" Background="#60CDFF" Foreground="#000000" FontWeight="Bold"/>
                        
                        <TextBlock Text="Transferencia directa de IP a IP (p2p)." HorizontalAlignment="Center" Margin="0,15,0,0" Foreground="#555555" FontSize="10"/>
                    </StackPanel>
                </TabItem>
            </TabControl>

            <!-- Log / Status Area -->
            <Border Grid.Row="3" Background="#0A0A0A" CornerRadius="6" Height="80" BorderBrush="#2D2D2D" BorderThickness="1" Margin="0,10,0,0">
                <ScrollViewer x:Name="scrollLog" VerticalScrollBarVisibility="Auto">
                    <TextBlock x:Name="txtLog" Text="[Consola de red lista]" Padding="10" FontSize="11" FontFamily="Consolas" Foreground="#00FF00" Opacity="0.7" TextWrapping="Wrap"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Border>
</Window>
