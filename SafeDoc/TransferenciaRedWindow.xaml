<Window x:Class="SafeDoc.TransferenciaRedWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Sincronización P2P" Height="400" Width="450"
        WindowStartupLocation="CenterOwner" Background="#1A1A1A" Foreground="White">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Transferencia Directa P2P" FontSize="20" FontWeight="Bold" Margin="0,0,0,20" Foreground="#60CDFF"/>

        <TabControl Grid.Row="1" Background="Transparent" BorderThickness="0">
            <TabItem Header="Enviar" Background="Transparent" BorderThickness="0">
                <StackPanel Margin="0,15,0,0">
                    <TextBlock Text="1. Asegúrate de estar en la misma red WiFi/LAN." TextWrapping="Wrap" Margin="0,0,0,10" Foreground="#AAAAAA"/>
                    <TextBlock x:Name="txtCodigoGenerado" Text="Código: SAFE-..." FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,20" Foreground="#60CDFF"/>
                    <Button x:Name="btnIniciarServidor" Content="Iniciar Servidor" Click="BtnIniciarServidor_Click" Height="40" Background="#2D2D2D" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Recibir" Background="Transparent" BorderThickness="0">
                <StackPanel Margin="0,15,0,0">
                    <TextBlock Text="Introduce el código que te dio el emisor:" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtCodigoInput" Height="40" Background="#2D2D2D" Foreground="White" BorderThickness="1" BorderBrush="#444444" FontSize="18" Padding="5" VerticalContentAlignment="Center"/>
                    <Button x:Name="btnConectar" Content="Conectar y Descargar" Click="BtnConectar_Click" Height="40" Margin="0,15,0,0" Background="#60CDFF" Foreground="Black" FontWeight="Bold" BorderThickness="0" Cursor="Hand"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <ScrollViewer Grid.Row="2" Height="100" Margin="0,20,0,0" Background="#101010">
            <TextBlock x:Name="txtLog" Text="Esperando acción..." Padding="10" FontSize="12" Foreground="#888888" TextWrapping="Wrap"/>
        </ScrollViewer>
    </Grid>
</Window>
